<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Montager.Avalonia.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Montager.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Montager" Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        Background="#1e1e1e"
        DragDrop.AllowDrop="True">

    <Window.Styles>
        <Style Selector="Button.sidebar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#858585"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.sidebar:pointerover">
            <Setter Property="Background" Value="#2a2d2e"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#0e639c"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="#1177bb"/>
        </Style>
        <Style Selector="Button.action:disabled">
            <Setter Property="Background" Value="#3a3d41"/>
            <Setter Property="Foreground" Value="#6e7681"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#3a3d41"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#4a4d51"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#28a745"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#34d058"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="48,*">
        <!-- Activity Bar -->
        <Border Grid.Column="0" Background="#333333">
            <StackPanel>
                <Button Classes="sidebar" ToolTip.Tip="Explorer" Margin="0,8,0,0">
                    <TextBlock Text="📁" FontSize="20"/>
                </Button>
                <Button Classes="sidebar" ToolTip.Tip="Processing">
                    <TextBlock Text="⚙" FontSize="20"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#323233" Padding="16,10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🎬" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Montager" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#cccccc" VerticalAlignment="Center"/>
                        <TextBlock Text="—" Foreground="#6e7681" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding VideoFileName}" 
                                   FontSize="13" Foreground="#858585" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="📁 Open" x:Name="BrowseButton"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Panel -->
            <Grid Grid.Row="1" ColumnDefinitions="280,*">
                
                <!-- Sidebar Panel -->
                <Border Grid.Column="0" Background="#252526" BorderBrush="#1e1e1e" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" Padding="12,10" Background="#2d2d2d">
                            <TextBlock Text="MONTAGER" FontSize="11" FontWeight="SemiBold" 
                                       Foreground="#bbbbbb"/>
                        </Border>
                        
                        <ScrollViewer Grid.Row="1" Padding="8">
                            <StackPanel Spacing="16">
                                <!-- Processing Section -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="PROCESSING" FontSize="11" Foreground="#858585" Margin="4,0,0,4"/>
                                    
                                    <Button Classes="action" Content="🔍 Detect Scene" 
                                            Command="{Binding DetectSceneCommand}" HorizontalAlignment="Stretch"/>
                                    <Button Classes="action" Content="🎤 Detect Voicemap" 
                                            Command="{Binding DetectVoicemapCommand}" HorizontalAlignment="Stretch"/>
                                    <Button Classes="secondary" Content="👁 Preview HTML" 
                                            Command="{Binding PreviewCommand}" HorizontalAlignment="Stretch"/>
                                    <Button Classes="success" Content="🎬 Render Montage" 
                                            Command="{Binding RenderCommand}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                
                                <!-- Speakers Section -->
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="11" Foreground="#858585" Margin="4,0,0,4">
                                        <Run Text="SPEAKERS ("/>
                                        <Run Text="{Binding SpeakerCount}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                    
                                    <ItemsControl ItemsSource="{Binding Speakers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2d2d2d" CornerRadius="4" Padding="10,8" Margin="0,2">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                                Background="#0078d4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" 
                                                                   Foreground="#cccccc" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <!-- Progress -->
                        <Border Grid.Row="2" Padding="12" Background="#2d2d2d" IsVisible="{Binding IsProcessing}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#cccccc"/>
                                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" 
                                             Foreground="#0078d4" Background="#3a3d41"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Video Preview & Timeline -->
                <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto" Background="#1e1e1e">
                    
                    <!-- Video Player Area -->
                    <Border Grid.Row="0" Background="#0d0d0d" Margin="1">
                        <Grid>
                            <!-- Placeholder when no video -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        IsVisible="{Binding !HasVideo}">
                                <TextBlock Text="🎬" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Drop video file here" FontSize="16" Foreground="#6e7681"
                                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                <TextBlock Text="or click Open to browse" FontSize="13" Foreground="#484f58"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- VLC Video View -->
                            <vlc:VideoView x:Name="VideoView" IsVisible="{Binding HasVideo}"
                                           MediaPlayer="{Binding MediaPlayer}"/>
                            
                            <!-- Play Controls Overlay -->
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                    Margin="0,0,0,20" IsVisible="{Binding HasVideo}">
                                <Border Background="#80000000" CornerRadius="6" Padding="8,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="secondary" Content="⏮" Command="{Binding SeekStartCommand}" 
                                                Width="32" Padding="0"/>
                                        <Button Classes="secondary" Content="⏪" Command="{Binding SeekBackCommand}"
                                                Width="32" Padding="0"/>
                                        <Button Classes="action" Command="{Binding PlayPauseCommand}" Width="40" Padding="0">
                                            <TextBlock Text="{Binding PlayPauseIcon}" FontSize="14"/>
                                        </Button>
                                        <Button Classes="secondary" Content="⏩" Command="{Binding SeekForwardCommand}"
                                                Width="32" Padding="0"/>
                                        <Button Classes="secondary" Content="⏭" Command="{Binding SeekEndCommand}"
                                                Width="32" Padding="0"/>
                                        <TextBlock Text="{Binding CurrentTimeDisplay}" FontSize="12" 
                                                   Foreground="#cccccc" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   FontFamily="Consolas,monospace"/>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Timeline -->
                    <Border Grid.Row="1" Background="#252526" Padding="16,12" IsVisible="{Binding HasVideo}">
                        <Grid RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Text="TIMELINE" FontSize="11" Foreground="#858585" Margin="0,0,0,8"/>
                            
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Background="#0078d4" Width="12" CornerRadius="2"
                                        Cursor="SizeWE" x:Name="TrimStartHandle" ToolTip.Tip="Drag to set trim start"/>
                                
                                <Border Grid.Column="1" Background="#3a3d41" Height="40" Margin="4,0" CornerRadius="4"
                                        x:Name="TimelineTrack" PointerPressed="OnTimelinePointerPressed">
                                    <Canvas x:Name="TimelineCanvas">
                                        <Border Width="2" Background="#ffffff" Height="40" x:Name="Playhead"/>
                                    </Canvas>
                                </Border>
                                
                                <Border Grid.Column="2" Background="#0078d4" Width="12" CornerRadius="2"
                                        Cursor="SizeWE" x:Name="TrimEndHandle" ToolTip.Tip="Drag to set trim end"/>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Log Output -->
                    <Border Grid.Row="2" Background="#1e1e1e" MaxHeight="150">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Background="#252526" Padding="12,6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="OUTPUT" FontSize="11" Foreground="#858585" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="secondary" Content="Clear" 
                                            Command="{Binding ClearLogCommand}" Padding="8,2" FontSize="11"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" MaxHeight="120">
                                <TextBox Text="{Binding LogOutput}" IsReadOnly="True" 
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         Background="Transparent" BorderThickness="0"
                                         FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                         Foreground="#9da5b4" Padding="12,8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="#007acc" Padding="8,4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12" Foreground="#ffffff"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                        <TextBlock FontSize="12" Foreground="#ffffff" IsVisible="{Binding HasVideo}"
                                   Text="{Binding VideoResolution}"/>
                        <TextBlock FontSize="12" Foreground="#ffffff" IsVisible="{Binding HasVideo}"
                                   Text="{Binding VideoDuration}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
