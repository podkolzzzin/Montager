<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Montager.Maui.MainPage"
             Title="Montager"
             BackgroundColor="#1a1a2e">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <!-- Title -->
            <Label 
                Text="🎬 Montager"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#eeeeee"
                HorizontalOptions="Center" />

            <!-- Drop Zone / File Display -->
            <Frame
                x:Name="DropZone"
                BackgroundColor="#16213e"
                BorderColor="#888888"
                CornerRadius="8"
                Padding="20"
                HeightRequest="100">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Label 
                        x:Name="FileLabel"
                        Text="📁 Select a video file"
                        TextColor="#888888"
                        FontSize="14"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Browse Button -->
            <Button
                x:Name="BrowseButton"
                Text="Browse..."
                BackgroundColor="#00ff88"
                TextColor="#000000"
                FontAttributes="Bold"
                Clicked="OnBrowseClicked" />

            <!-- Action Buttons -->
            <HorizontalStackLayout
                Spacing="10"
                HorizontalOptions="Center">
                
                <Button
                    x:Name="PreviewButton"
                    Text="👁️ Preview"
                    BackgroundColor="#3498db"
                    TextColor="#ffffff"
                    FontAttributes="Bold"
                    IsEnabled="False"
                    Clicked="OnPreviewClicked" />
                
                <Button
                    x:Name="RenderButton"
                    Text="🎬 Render"
                    BackgroundColor="#e74c3c"
                    TextColor="#ffffff"
                    FontAttributes="Bold"
                    IsEnabled="False"
                    Clicked="OnRenderClicked" />
            </HorizontalStackLayout>

            <!-- Status Label -->
            <Label
                x:Name="StatusLabel"
                Text="Select a video file to begin"
                TextColor="#888888"
                FontSize="12"
                HorizontalOptions="Center" />

            <!-- Progress Indicator -->
            <ActivityIndicator
                x:Name="ProgressIndicator"
                Color="#00ff88"
                IsVisible="False"
                IsRunning="False"
                HeightRequest="30" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
